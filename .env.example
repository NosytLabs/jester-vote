# TopJester Environment Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# Core Application Settings
# =============================================================================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# JWT/Cookie Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database
DATABASE_URL=mysql://user:password@localhost:3306/topjester

# =============================================================================
# Multi-Platform OAuth Configuration
# =============================================================================

# Twitch OAuth - https://dev.twitch.tv/console
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# YouTube/Google OAuth - https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# Kick OAuth - https://kick.com/developer/apps
KICK_CLIENT_ID=your-kick-client-id
KICK_CLIENT_SECRET=your-kick-client-secret

# =============================================================================
# Legacy Manus OAuth (Deprecated - will be removed)
# =============================================================================
# These are kept for backward compatibility during migration
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# =============================================================================
# Email Configuration (Optional - for nomination notifications)
# =============================================================================
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@topjester.com
EMAIL_API_KEY=

# =============================================================================
# Built-in Forge API (Optional)
# =============================================================================
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
