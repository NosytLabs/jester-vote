# Jester-Vote Environment Configuration

# ============================================
# DATABASE
# ============================================
DATABASE_URL=mysql://user:password@localhost:3306/jestervote

# ============================================
# CORE SETTINGS
# ============================================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ============================================
# OAUTH - TWITCH
# Register at: https://dev.twitch.tv/console/apps
# Callback URL: http://localhost:3000/api/oauth/callback
# ============================================
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# ============================================
# OAUTH - YOUTUBE (GOOGLE)
# Register at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/oauth/callback
# ============================================
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# ============================================
# OAUTH - KICK (RECOMMENDED)
# Register at: https://kick.com/developer/apps
# Callback URL: http://localhost:3000/api/oauth/callback
# ============================================
KICK_CLIENT_ID=your_kick_client_id
KICK_CLIENT_SECRET=your_kick_client_secret

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@topjester.com
ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# ANALYTICS (Optional)
# ============================================
VITE_ANALYTICS_ENDPOINT=https://analytics.yourdomain.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================
# ============================================
# LEGACY (Deprecated - will be removed)
# ============================================
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
